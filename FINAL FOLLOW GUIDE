## STEP 8 — Create Ansible Deploy Playbook

On VM1:

```bash
cat > /etc/ansible/deploy-maven.yml << 'EOF'
---
- name: Deploy Maven Web Application to Tomcat
  hosts: appserver
  become: yes
  tasks:

    - name: Stop Tomcat
      systemd:
        name: tomcat
        state: stopped
      ignore_errors: yes

    - name: Remove old deployment
      file:
        path: "{{ item }}"
        state: absent
      loop:
        - /opt/tomcat/webapps/maven-web-application
        - /opt/tomcat/webapps/maven-web-application.war

    - name: Copy WAR to Tomcat
      copy:
        src: /var/lib/jenkins/workspace/maven-web-application/target/maven-web-application.war
        dest: /opt/tomcat/webapps/maven-web-application.war
        mode: '0644'

    - name: Start Tomcat
      systemd:
        name: tomcat
        state: started

    - name: Wait for port 8080
      wait_for:
        port: 8080
        delay: 10
        timeout: 60
EOF
```

Syntax check:

```bash
sudo -u jenkins ansible-playbook /etc/ansible/deploy-maven.yml --syntax-check
```

