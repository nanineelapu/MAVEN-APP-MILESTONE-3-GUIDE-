## STEP 4 — VM2 Setup (SonarQube)

Connect to VM2 via PuTTY then run:

```bash
sudo su -
nano sonar.sh
```

Paste this script:

```bash
#!/bin/bash
set -e

echo "=== Update System ==="
dnf update -y

echo "=== Install Java 17 ==="
dnf install java-17-amazon-corretto -y
java -version

echo "=== Set vm.max_map_count ==="
sysctl -w vm.max_map_count=524288
echo "vm.max_map_count=524288" >> /etc/sysctl.conf

echo "=== Add Swap (2GB) ==="
dd if=/dev/zero of=/swapfile bs=1M count=2048
chmod 600 /swapfile
mkswap /swapfile
swapon /swapfile
echo '/swapfile none swap sw 0 0' >> /etc/fstab
free -h

echo "=== Install wget, unzip ==="
dnf install wget unzip -y

echo "=== Download SonarQube 10.4.1 ==="
cd /tmp
wget -O sonarqube.zip https://binaries.sonarsource.com/Distribution/sonarqube/sonarqube-10.4.1.88267.zip

echo "=== Extract SonarQube ==="
rm -rf /opt/sonarqube
unzip -q sonarqube.zip
mv sonarqube-10.4.1.88267 /opt/sonarqube

echo "=== Create sonar user ==="
id sonar >/dev/null 2>&1 || useradd sonar
chown -R sonar:sonar /opt/sonarqube

echo "=== Start SonarQube ==="
sudo -u sonar /opt/sonarqube/bin/linux-x86-64/sonar.sh start

echo "=== Waiting 90 seconds ==="
sleep 90

echo "=== Status ==="
sudo -u sonar /opt/sonarqube/bin/linux-x86-64/sonar.sh status

echo "Open: http://YOUR-VM2-PUBLIC-IP:9000"
echo "Login: admin / admin"
```

